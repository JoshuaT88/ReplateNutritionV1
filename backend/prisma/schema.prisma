generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ProfileType {
  HUMAN
  PET
}

enum ItemPriority {
  LOW
  MEDIUM
  HIGH
}

enum ShoppingItemStatus {
  PENDING
  PICKED_UP
  OUT_OF_STOCK
  TOO_EXPENSIVE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  fullName      String   @map("full_name")
  passwordHash  String   @map("password_hash")
  role          UserRole @default(MEMBER)
  householdId   String?  @map("household_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  preferences        UserPreferences?
  profiles           Profile[]
  recommendations    Recommendation[]
  mealPlans          MealPlan[]
  shoppingLists      ShoppingList[]
  shoppingHistories  ShoppingHistory[]
  shoppingSessions   ShoppingSession[]
  priceSubmissions   PriceSubmission[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationCodes EmailVerificationCode[]
  macroLogs          MacroLog[]
  shareTokens        ShareToken[]
  pushSubscriptions  PushSubscription[]
  pantryItems        PantryItem[]
  shoppingListGroups ShoppingListGroup[]
  customMeals        CustomMeal[]
  activityLogs          ActivityLog[]
  ownedHousehold        Household?      @relation("HouseholdOwner")
  householdMembership   HouseholdMember?
  storeCorrections      StoreCorrection[]
  inAppNotifications    InAppNotification[]
  familySuggestions     FamilyMemberSuggestion[]
  dataExportUrl         String?   @map("data_export_url")
  dataExportExpiresAt   DateTime? @map("data_export_expires_at")
  dataExportRequestedAt DateTime? @map("data_export_requested_at")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  purpose   String   @default("notifications")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_codes")
}

model UserPreferences {
  id                    String  @id @default(uuid())
  userId                String  @unique @map("user_id")
  zipCode               String? @map("zip_code")
  budget                Float?
  currency              String  @default("USD")
  theme                 String  @default("light")
  firstVisitCompleted   Boolean @default(false) @map("first_visit_completed")
  profilePictureUrl     String? @map("profile_picture_url")
  householdType         String? @map("household_type")
  mealReminders         Boolean @default(true) @map("meal_reminders")
  shoppingAlerts        Boolean @default(true) @map("shopping_alerts")
  priceDropAlerts       Boolean @default(false) @map("price_drop_alerts")
  emailNotificationsEnabled Boolean @default(false) @map("email_notifications_enabled")
  emailNotificationsDisclosureAccepted Boolean @default(false) @map("email_notifications_disclosure_accepted")
  emailNotificationsDisclosureAcceptedAt DateTime? @map("email_notifications_disclosure_accepted_at")
  timezone              String  @default("America/New_York") @map("timezone")
  budgetLastResetAt     DateTime? @map("budget_last_reset_at")
  gpsAppPreference      String? @map("gps_app_preference")
  preferredStoreIds     Json?   @map("preferred_store_ids")
  pinnedNavItems        Json?   @map("pinned_nav_items")
  shoppingFrequency     String? @map("shopping_frequency")
  shoppingDay           String? @map("shopping_day")
  perTripBudgetAllocation Float? @map("per_trip_budget_allocation")
  organizerRole         String? @map("organizer_role")
  city                  String?
  state                 String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Profile {
  id                  String      @id @default(uuid())
  userId              String      @map("user_id")
  name                String
  type                ProfileType
  petType             String?     @map("pet_type")
  breed               String?
  dietType            String?     @map("diet_type")
  feedingSchedule     Json?       @map("feeding_schedule")
  age                 Int?
  weight              Float?
  avatarUrl           String?     @map("avatar_url")
  allergies           String[]    @default([])
  intolerances        String[]    @default([])
  dietaryRestrictions String[]    @default([]) @map("dietary_restrictions")
  specialConditions   String[]    @default([]) @map("special_conditions")
  foodPreferences     String[]    @default([]) @map("food_preferences")
  foodDislikes        String[]    @default([]) @map("food_dislikes")
  criticalAllergies   String[]    @default([]) @map("critical_allergies")
  notes               String?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]
  mealPlans       MealPlan[]
  macroLogs       MacroLog[]
  activityLogs    ActivityLog[]

  @@map("profiles")
}

model Recommendation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  profileId    String   @map("profile_id")
  itemName     String   @map("item_name")
  itemType     String   @map("item_type")
  category     String
  reason       String
  ingredients  String[] @default([])
  alternatives String[] @default([])
  priceRange   String?  @map("price_range")
  isFavorite   Boolean  @default(false) @map("is_favorite")
  rating       Int?
  nutrition    Json?
  texture      String?
  safetyFlag   String?  @map("safety_flag")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

model MealPlan {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  profileId        String   @map("profile_id")
  date             DateTime @db.Date
  mealType         String   @map("meal_type")
  mealName         String   @map("meal_name")
  ingredients      String[] @default([])
  preparationNotes String?  @map("preparation_notes")
  calories         Int?
  protein          Float?
  carbs            Float?
  fat              Float?
  fiber            Float?
  servings         Int?     @default(1)
  completed        Boolean  @default(false)
  safetyFlag       String?  @map("safety_flag")
  createdAt        DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("meal_plans")
}

model ShoppingList {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  listGroupId  String?      @map("list_group_id")
  itemName     String       @map("item_name")
  category     String?
  quantity     String?
  profileIds   String[]     @default([]) @map("profile_ids")
  checked      Boolean      @default(false)
  priority     ItemPriority @default(MEDIUM)
  notes        String?
  dealNote     String?  @map("deal_note")
  estimatedPrice Float?     @map("estimated_price")
  assignedStore  String?    @map("assigned_store")
  sourceRef    String?      @map("source_ref")
  createdAt    DateTime     @default(now()) @map("created_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listGroup ShoppingListGroup? @relation(fields: [listGroupId], references: [id], onDelete: SetNull)

  @@map("shopping_lists")
}

model ShoppingListGroup {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  storeName   String?  @map("store_name")
  storeAddress String? @map("store_address")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingList[]

  @@map("shopping_list_groups")
}

model ShoppingHistory {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  storeName          String   @map("store_name")
  storeLocation      String?  @map("store_location")
  estimatedCost      Float?   @map("estimated_cost")
  actualCost         Float?   @map("actual_cost")
  shoppingDate       DateTime @map("shopping_date")
  itemsPickedUp      Json?    @map("items_picked_up")
  itemsOutOfStock    Json?    @map("items_out_of_stock")
  itemsTooExpensive  Json?    @map("items_too_expensive")
  secondaryStore     String?  @map("secondary_store")
  secondaryStoreCost Float?   @map("secondary_store_cost")
  receiptUrls        String[] @default([]) @map("receipt_urls")
  notes              String?
  durationSeconds    Int?     @map("duration_seconds")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shopping_histories")
}

model ShoppingSession {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  selectedStore Json?    @map("selected_store")
  storeResults  Json?    @map("store_results")
  itemStatuses  Json?    @map("item_statuses")
  itemPrices    Json?    @map("item_prices")
  sessionDate   DateTime @default(now()) @map("session_date")
  completed     Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shopping_sessions")
}

model PriceSubmission {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  itemName    String   @map("item_name")
  storeName   String   @map("store_name")
  zipRegion   String   @map("zip_region")
  actualPrice Float    @map("actual_price")
  quantity    Int      @default(1)
  unit        String?
  submittedAt DateTime @default(now()) @map("submitted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemName, storeName, zipRegion])
  @@map("price_submissions")
}

model StoreItemAverage {
  id              String   @id @default(uuid())
  itemName        String   @map("item_name")
  storeName       String   @map("store_name")
  zipRegion       String   @map("zip_region")
  avgPrice        Float    @map("avg_price")
  previousAvgPrice Float?  @map("previous_avg_price")
  submissionCount Int      @map("submission_count")
  lastUpdated     DateTime @default(now()) @map("last_updated")

  @@unique([itemName, storeName, zipRegion])
  @@map("store_item_averages")
}

model AisleLocation {
  id               String   @id @default(uuid())
  itemName         String   @map("item_name")
  storeName        String   @map("store_name")
  zipRegion        String   @default("") @map("zip_region")
  aisleLocation    String   @map("aisle_location")
  verifiedCount    Int      @default(1) @map("verified_count")
  disputeCount     Int      @default(0) @map("dispute_count")
  confidenceScore  Float    @default(1.0) @map("confidence_score")
  lastVerifiedDate DateTime @default(now()) @map("last_verified_date")
  createdBy        String?  @map("created_by")

  @@unique([itemName, storeName, zipRegion])
  @@index([storeName, zipRegion])
  @@index([confidenceScore])
  @@map("aisle_locations")
}

model PantryItem {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  itemName     String    @map("item_name")
  category     String?
  quantity     String?
  unit         String?
  expiresAt    DateTime? @map("expires_at")
  purchasedAt  DateTime? @map("purchased_at")
  notes        String?
  lowStockAlert Boolean  @default(false) @map("low_stock_alert")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, expiresAt])
  @@map("pantry_items")
}

model SavedRecipe {
  id           String   @id @default(uuid())
  externalId   String?  @map("external_id")
  source       String   @default("themealdb") // themealdb | custom
  name         String
  category     String?
  cuisine      String?
  instructions String?
  thumbnail    String?
  ingredients  Json     // [{ name, measure }]
  tags         String[] @default([])
  userId       String?  @map("user_id") // null = global cache
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([externalId, source])
  @@index([userId])
  @@index([category, cuisine])
  @@map("saved_recipes")
}

model MacroLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  profileId  String?  @map("profile_id")
  date       DateTime @db.Date
  mealName   String   @map("meal_name")
  calories   Int?
  protein    Float?
  carbs      Float?
  fat        Float?
  fiber      Float?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@map("macro_logs")
}

model ShareToken {
  id        String   @id @default(uuid())
  token     String   @unique @default(cuid())
  userId    String   @map("user_id")
  snapshot  Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("share_tokens")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model CustomMeal {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  name               String
  mealType           String   @map("meal_type")
  ingredients        String[] @default([])
  preparationNotes   String?  @map("preparation_notes")
  calories           Int?
  protein            Float?
  carbs              Float?
  fat                Float?
  fiber              Float?
  servings           Int?     @default(1)
  prepTime           Int?     @map("prep_time")
  tags               String[] @default([])
  photoUrl           String?  @map("photo_url")
  ingredientScaling  Json?    @map("ingredient_scaling")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("custom_meals")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  profileId   String?  @map("profile_id")
  entityType  String   @map("entity_type") // shopping_item | meal | session | pantry | recommendation
  entityId    String?  @map("entity_id")
  action      String   // checked_off | completed | who_ate | started | ended | cancelled | updated | acted_on
  performedBy String?  @map("performed_by") // profile id or 'user'
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, entityType])
  @@index([profileId, createdAt])
  @@map("activity_logs")
}

model Household {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @unique @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   User              @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members HouseholdMember[]
  suggestions FamilyMemberSuggestion[]

  @@map("households")
}

model HouseholdMember {
  id            String   @id @default(uuid())
  householdId   String   @map("household_id")
  userId        String?  @unique @map("user_id")
  inviteEmail   String   @map("invite_email")
  role          String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  inviteStatus  String   @default("PENDING") @map("invite_status") // PENDING | ACCEPTED | DECLINED
  inviteToken   String?  @unique @map("invite_token")
  permissions   Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([inviteToken])
  @@map("household_members")
}

model StoreCorrection {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  storeName      String   @map("store_name")
  currentAddress String   @map("current_address")
  correction     String   // the corrected address the user provides
  notes          String?
  status         String   @default("pending") // pending | approved | rejected
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("store_corrections")
}

model StoreOverride {
  id           String   @id @default(uuid())
  storeName    String   @unique @map("store_name")
  address      String
  correctedBy  String?  @map("corrected_by")
  approvedAt   DateTime @default(now()) @map("approved_at")

  @@map("store_overrides")
}

model StoreCache {
  id         String   @id @default(uuid())
  cacheKey   String   @unique @map("cache_key") // "zip:<zipcode>" or "name:<normalized_query>"
  queryType  String   @map("query_type") // "zip" | "name"
  results    Json
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("store_cache")
}

model PriceCache {
  id             String   @id @default(uuid())
  cacheKey       String   @unique @map("cache_key") // "<itemName>::<storeName>::<zipRegion>"
  itemName       String   @map("item_name")
  storeName      String   @map("store_name")
  zipRegion      String   @default("") @map("zip_region")
  estimatedPrice Float    @map("estimated_price")
  source         String   @default("ai") // ai | reference
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([itemName, storeName, zipRegion])
  @@map("price_cache")
}

model InAppNotification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("in_app_notifications")
}

model FamilyMemberSuggestion {
  id                String   @id @default(uuid())
  householdId       String   @map("household_id")
  requestedByUserId String   @map("requested_by_user_id")
  type              String   // 'meal' | 'shopping_item'
  title             String
  details           String?
  status            String   @default("PENDING") // PENDING | APPROVED | DENIED
  adminNotes        String?  @map("admin_notes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  requestedByUser User      @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([status])
  @@map("family_member_suggestions")
}
